<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_margin="12dp"
    android:background="@drawable/movie_card_background"
    android:elevation="8dp">

    <!-- Movie Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/movie_title_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Movie Title"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:maxLines="2"
                android:ellipsize="end" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/movie_genre_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Drama"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:background="@drawable/genre_badge_background"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/movie_year_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2023"
                    android:textSize="12sp"
                    android:textColor="@color/hint_color" />

            </LinearLayout>

        </LinearLayout>

        <ImageButton
            android:id="@+id/movie_delete_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/delete_button_background"
            android:src="@android:drawable/ic_menu_delete"
            android:contentDescription="Delete Movie"
            android:scaleType="centerInside"
            android:padding="8dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_color"
        android:layout_marginBottom="12dp" />

    <!-- Director and Budget Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Director"
                android:textSize="12sp"
                android:textColor="@color/hint_color"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/movie_director_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Director Name"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Budget"
                android:textSize="12sp"
                android:textColor="@color/hint_color"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/movie_budget_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="$100M"
                android:textSize="14sp"
                android:textColor="@color/accent_color"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

    </LinearLayout>

    <!-- Description -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Plot Summary"
            android:textSize="12sp"
            android:textColor="@color/hint_color"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/movie_description_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description of the movie"
            android:textSize="13sp"
            android:textColor="@color/white"
            android:maxLines="3"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_color"
        android:layout_marginBottom="12dp" />

    <!-- Cast Section Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cast"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/add_actor_btn"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ Actor"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@drawable/button_add_background" />

    </LinearLayout>

    <!-- Actors RecyclerView (container for actors) -->
    <LinearLayout
        android:id="@+id/actors_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/actors_bg"
        android:padding="8dp" />

    <TextView
        android:id="@+id/no_actors_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No actors assigned yet"
        android:textSize="13sp"
        android:textColor="@color/hint_color"
        android:gravity="center"
        android:padding="12dp"
        android:background="@drawable/actors_bg" />

</LinearLayout>

